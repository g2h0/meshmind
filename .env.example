# Required - API key for AI chat responses
# Works with any OpenAI-compatible API (xAI, OpenAI, OpenRouter, Groq, Ollama, etc.)
# Set ai_base_url and ai_model in settings.json to match your provider
AI_API_KEY=your_api_key_here

# Optional - Tomorrow.io weather API key (https://www.tomorrow.io/)
# Provides enhanced weather data; if not set, NOAA is used as the sole weather source
TOMORROW_IO_API_KEY=your_tomorrow_io_api_key_here

# Optional - AirNow API key for Air Quality Index (free: https://www.airnowapi.org/)
AIRNOW_API_KEY=your_airnow_api_key_here
